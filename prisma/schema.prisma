// Veteranos - football scheduling app
// Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PLAYER
}

enum PlayerKind {
  ABO       // Abo player (fixed slot)
  WAITLIST  // Waitlist player
}

enum SignupStatus {
  IN          // Abo player confirmed
  OUT         // Abo player declined
  WAITLIST    // Waitlist player signed up for this match
}

enum PaymentStatus {
  NONE        // no payment required
  PENDING     // pending
  PAID        // paid
}

enum Position {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  STRIKER
  ANY
}

enum TeamColor {
  BLUE
  RED
  WHITE
  BLACK
}

model User {
  id             String               @id @default(cuid())
  email          String               @unique
  passwordHash   String
  role           Role                 @default(PLAYER)
  player         Player?
  invitations    Invitation[]         @relation("InvitationCreator")
  passwordResets PasswordResetToken[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  usedAt    DateTime?
  // 'self' if requested through /forgot-password, otherwise the userId of the admin
  // who generated it. Used so admins can audit and so we can render the link in the UI.
  source    String    @default("self")

  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Invitation {
  id          String    @id @default(cuid())
  token       String    @unique
  label       String?
  active      Boolean   @default(true)
  uses        Int       @default(0)
  maxUses     Int?
  expiresAt   DateTime?

  createdById String?
  createdBy   User?     @relation("InvitationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([active])
}

model Player {
  id          String     @id @default(cuid())
  userId      String?    @unique
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  firstName   String
  lastName    String?
  nickname    String?
  avatarUrl   String?

  kind        PlayerKind @default(WAITLIST)
  // Position within the respective list (1, 2, 3, ...) - determines replacement order
  rank        Int        @default(0)

  // Contact / payment
  paypalName  String?
  paypalLink  String?
  phone       String?
  notes       String?

  // Skills (0-100)
  overall     Int        @default(50)
  technique   Int        @default(50)
  speed       Int        @default(50)
  stamina     Int        @default(50)
  defense     Int        @default(50)
  offense     Int        @default(50)
  passing     Int        @default(50)
  shooting    Int        @default(50)
  goalkeeping Int        @default(20)
  position    Position   @default(ANY)

  active      Boolean    @default(true)

  signups     Signup[]
  teamSlots   TeamSlot[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([kind, rank])
}

model Match {
  id          String     @id @default(cuid())
  date        DateTime
  durationMin Int        @default(90)
  location    String?
  notes       String?

  // When locked, sign-up changes are no longer allowed
  locked      Boolean    @default(false)

  // Number of teams to generate (2 - 4)
  teamCount   Int        @default(2)

  signups     Signup[]
  teams       Team[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([date])
}

model Signup {
  id            String        @id @default(cuid())
  matchId       String
  match         Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId      String
  player        Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)

  status        SignupStatus
  // Order within the respective list (waitlist / declines)
  rank          Int           @default(0)

  // Payment status between this waitlist player and the abo they're replacing.
  // Only relevant when this waitlist player has stepped in for an abo.
  paymentStatus PaymentStatus @default(NONE)
  paymentNote   String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([matchId, playerId])
  @@index([matchId, status, rank])
}

model Team {
  id        String     @id @default(cuid())
  matchId   String
  match     Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)

  name      String
  color     TeamColor

  // Aggregated stats (for the overview UI)
  avgOverall   Float    @default(0)
  avgDefense   Float    @default(0)
  avgOffense   Float    @default(0)
  avgSpeed     Float    @default(0)
  comment      String?

  slots     TeamSlot[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([matchId, color])
}

model TeamSlot {
  id        String  @id @default(cuid())
  teamId    String
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  position  Position @default(ANY)

  @@unique([teamId, playerId])
  @@index([teamId])
}
