# PostgreSQL Connection (Railway stellt diese automatisch bereit)
DATABASE_URL="postgresql://user:password@host:5432/veteranos"

# Auth – frisch generieren, z.B. mit:  openssl rand -base64 32
AUTH_SECRET="bitte-eigenen-zufaelligen-string-setzen"

# Initialer Admin (Erstanlage durch `npm run db:seed`)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="bitte-aendern"

# Demo-Daten beim Seed mit anlegen?
SEED_DEMO_PLAYERS="false"

# Port (Railway setzt das automatisch)
PORT="3000"
